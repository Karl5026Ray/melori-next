# MELORI Music Platform — environment variables (per BUILD SPEC v1.1 Section 6)
# Copy to .env.local for local dev. NEVER commit .env.local. Set real values in Vercel UI.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Stripe (Phase 2 — use test keys for Preview/Development, live keys for Production)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App URL (Production: https://melorimusic.org ; Preview: https://<preview>.vercel.app)
NEXT_PUBLIC_APP_URL=

# Agora (real-time voice for Spaces). App ID is public; certificate is server-only.
NEXT_PUBLIC_AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# PubNub (presence signaling + ephemeral room-vanish webhooks).
# publish/subscribe keys are safe to expose; SECRET key is server-only (PAM grants).
PUBNUB_PUBLISH_KEY=
PUBNUB_SUBSCRIBE_KEY=
PUBNUB_SECRET_KEY=
# Shared secret the PubNub Function forwards on the presence webhook so only
# PubNub can end rooms. Used as x-melori-webhook-secret or HMAC in x-melori-signature.
PUBNUB_WEBHOOK_SECRET=

# Cron secret (Vercel Cron -> /api/cron/mm-social-prune safety-net sweeps).
CRON_SECRET=
