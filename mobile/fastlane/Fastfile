# Fastlane config for the Melori Music iOS app (Capacitor wrapper).
#
# Runs on the macOS GitHub Actions runner (see .github/workflows/ios-build.yml)
# but also works locally on your Mac if you set the same env vars.
#
# Bundle ID: org.melorimusic.app   App Store Connect Apple ID: 6792791603

default_platform(:ios)

APP_IDENTIFIER = "org.melorimusic.app"
# Anchor all paths to the mobile/ dir (parent of this fastlane/ folder) so
# they resolve regardless of Fastlane's runtime working directory.
MOBILE_DIR = File.expand_path("..", __dir__)
XCODE_PROJECT  = File.join(MOBILE_DIR, "ios/App/App.xcodeproj")
XCODE_WORKSPACE = File.join(MOBILE_DIR, "ios/App/App.xcworkspace")
SCHEME = "App"
TEAM_ID = "ZDPS766DHY"
PROFILE_NAME = "Melori Music App Store"

platform :ios do
  desc "Build and upload a signed build to App Store Connect / TestFlight"
  lane :release do
    # App Store Connect API key (from env written by the workflow).
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )

    build_number = ENV["BUILD_NUMBER"] || "1"

    # ------------------------------------------------------------------
    # Signing: let Fastlane create/fetch a VALID distribution certificate
    # and App Store provisioning profile via the App Store Connect API key.
    # This avoids relying on a manually-created cert that Xcode can reject
    # as "not valid for code signing".
    # ------------------------------------------------------------------

    # Create or download a distribution certificate into the CI keychain.
    # (get_certificates defaults to a distribution cert; 'development: false'
    # makes that explicit. It does NOT accept a 'type:' option.)
    get_certificates(
      development: false,
      api_key: api_key,
      output_path: "./ios/App/certs",
      keychain_path: ENV["MATCH_KEYCHAIN_NAME"],
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"]
    )

    # Create or fetch the App Store provisioning profile for this app id.
    get_provisioning_profile(
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      provisioning_name: PROFILE_NAME,
      output_path: "./ios/App/profiles",
      filename: "melori_appstore.mobileprovision"
    )
    profile_name = lane_context[SharedValues::SIGH_NAME] || PROFILE_NAME

    # Set version (1.0) and the build number on the generated Xcode project.
    increment_version_number(
      version_number: "1.0",
      xcodeproj: XCODE_PROJECT
    )
    increment_build_number(
      build_number: build_number,
      xcodeproj: XCODE_PROJECT
    )

    # Manual signing pointed at the freshly-fetched cert + profile.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODE_PROJECT,
      team_id: TEAM_ID,
      targets: ["App"],
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name
    )

    # Build the signed .ipa from the CocoaPods WORKSPACE (never the bare
    # .xcodeproj) so the Capacitor pod is compiled and linked. Building the
    # project alone fails with "Unable to find module dependency: 'Capacitor'".
    unless File.exist?(XCODE_WORKSPACE)
      UI.user_error!("Expected CocoaPods workspace at #{XCODE_WORKSPACE} (run pod install)")
    end
    build_app(
      workspace: XCODE_WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./ios/App/build",
      output_name: "MeloriMusic.ipa",
      clean: true,
      export_team_id: TEAM_ID,
      export_options: {
        teamID: TEAM_ID,
        method: "app-store",
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        },
        signingStyle: "manual"
      }
    )

    # Upload to TestFlight (does not auto-submit to review — you promote it
    # from App Store Connect when ready).
    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
