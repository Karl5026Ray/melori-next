# Fastlane config for the Melori Music iOS app (Capacitor wrapper).
#
# Runs on the macOS GitHub Actions runner (see .github/workflows/ios-build.yml)
# but also works locally on your Mac if you set the same env vars.
#
# Bundle ID: org.melorimusic.app   App Store Connect Apple ID: 6792791603

default_platform(:ios)

APP_IDENTIFIER = "org.melorimusic.app"
XCODE_PROJECT  = "./ios/App/App.xcodeproj"
XCODE_WORKSPACE = "./ios/App/App.xcworkspace"
SCHEME = "App"

platform :ios do
  desc "Build and upload a signed build to App Store Connect / TestFlight"
  lane :release do
    # App Store Connect API key (from env written by the workflow).
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )

    build_number = ENV["BUILD_NUMBER"] || "1"

    # Set version (1.0) and the build number on the generated Xcode project.
    increment_version_number(
      version_number: "1.0",
      xcodeproj: XCODE_PROJECT
    )
    increment_build_number(
      build_number: build_number,
      xcodeproj: XCODE_PROJECT
    )

    # Force manual signing with the imported distribution cert + profile.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODE_PROJECT,
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution"
    )

    # Build the signed .ipa. CocoaPods creates the workspace; prefer it if present.
    build_app(
      workspace: File.exist?(XCODE_WORKSPACE) ? XCODE_WORKSPACE : nil,
      project: File.exist?(XCODE_WORKSPACE) ? nil : XCODE_PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./ios/App/build",
      output_name: "MeloriMusic.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "Melori Music App Store"
        },
        signingStyle: "manual"
      }
    )

    # Upload to TestFlight (does not auto-submit to review — you promote it
    # from App Store Connect when ready).
    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
