{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/studio/gallery/[id]/images/route.ts": {
      "maxDuration": 60,
      "memory": 3009
    },
    "src/app/api/gallery/upload/route.ts": {
      "maxDuration": 60,
      "memory": 3009
    }
  },
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/mm-social-prune",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/mm-presence-reap",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/photo-balance-reminders",
      "schedule": "0 14 * * *"
    }
  ]
}
